  "identifier": "S1151",
  "title": "Establishes an adopt-a-rural cemetery program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the secretary of state to develop and implement an adopt-a-rural-cemetery program for the purposes of improving, repairing, and maintaining cemeteries in rural communities which are registered with and overseen by the division of cemeteries; allows municipalities to opt in to the program."
    }
