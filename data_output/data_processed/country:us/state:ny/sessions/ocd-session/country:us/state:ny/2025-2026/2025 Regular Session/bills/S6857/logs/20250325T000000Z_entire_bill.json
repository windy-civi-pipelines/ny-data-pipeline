  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"blocking illegitimate reservations and defending individual entertainment (BIRDIE) act\" to prohibit third-party reservation services from listing, advertising, promoting or selling reservations for state-owned golf courses; provides monies received from penalties shall be deposited in the golf fund."
    }
