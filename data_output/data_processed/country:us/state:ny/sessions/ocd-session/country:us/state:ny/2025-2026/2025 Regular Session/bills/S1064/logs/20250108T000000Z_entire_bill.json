  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the purchase of glyphosate by any state department, agency, public benefit corporation or any pesticide applicator employed thereby as a contractor or subcontractor and the application of glyphosate on property owned, operated or leased by the state."
