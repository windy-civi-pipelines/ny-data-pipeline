  "identifier": "A6758",
  "title": "Relates to a pharmacy's obligation to properly dispense or refill a prescription for a drug or device, or a non-prescription drug or device",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a pharmacy is obligated to properly dispense or refill a prescription for a drug or device, or a non-prescription drug or device regardless of the ethical, moral or religious beliefs of any employee of such pharmacy."
    }
