  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to Warren county no longer providing community colleges funding with excess funds from the collection of mortgage recording taxes as such money is allocated to the CDTA; extends the effectiveness of provisions relating to an additional Warren county mortgage recording tax to December 1, 2027."
    }
  ],
