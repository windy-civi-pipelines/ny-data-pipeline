  "identifier": "S614",
  "title": "Relates to enrollment in medical assistance programs for incarcerated individuals",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides presumptive eligibility for medical assistance benefits for persons released from correctional facilities for at least sixty days following release; provides for enrollment of such individuals upon release upon application, if eligible."
    }
  ],
