  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits a military spouse to practice an occupation upon submission of licensure, certification or registration to practice an equivalent occupation issued by any other state; provided the licensure standards are not lower than those of this state."
