{
  "legislative_session": "2025-2026",
  "identifier": "A5882",
  "title": "Relates to payments by a pharmacy benefit manager to participating pharmacies",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a pharmacy benefit manager to pay a participating pharmacy at minimum at the national average drug acquisition cost (NADAC) rate, or at the pharmacy acquisition cost rate if greater or there is not a NADAC rate, plus a professional dispensing fee that is at minimum the professional dispensing fee paid under the state medical assistance program."
    }
  ],
