  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that no state or local correctional facility shall deny entry to a person visiting such facility due to the fact that such person is menstruating or has a contraceptive device or appears on body scan imaging or alternative methods to have or be using a menstrual product or contraceptive device."
    }
  ],
