  "identifier": "A5821",
  "title": "Relates to media literacy education",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"media literacy act\"; requires teachers and library media specialists to complete professional development related to media literacy education; requires a school library media specialist in each elementary, intermediate, middle, junior high and senior high school; directs the commissioner of education to appoint a media literacy advisory committee to study the teaching of media literacy; creates a media literacy advisory committee to annually review policy and procedures on media literacy."
    }
  ],
