  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts provisions providing protection to employees from retaliatory actions by employers where such employees report improper business activities; applicable to employees who in good faith reasonably believe that an improper business activity has or will occur, based on information that the employees reasonably believe to be true; provides remedies and relief."
    }
