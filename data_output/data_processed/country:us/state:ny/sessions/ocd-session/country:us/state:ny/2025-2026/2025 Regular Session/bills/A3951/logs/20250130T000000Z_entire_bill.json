{
  "legislative_session": "2025-2026",
  "identifier": "A3951",
  "title": "Enacts the New York state antisemitism vandalism act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the New York state antisemitism vandalism act which establishes the crime of vandalism of pro-Israel print, which provides a class A misdemeanor for any individual who intentionally destroys, damages, removes, or causes to be destroyed, damaged or removed any banner, poster, flyer or billboard which is located in a public space, where the intent or purpose of such banner, poster, flyer or billboard is to bring awareness for Israeli individuals who have been victims of a crime, or to positively support the country or citizens of Israel in any way."
    }
  ],
