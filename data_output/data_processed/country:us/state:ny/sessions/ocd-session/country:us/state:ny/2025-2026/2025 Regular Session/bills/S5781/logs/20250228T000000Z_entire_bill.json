  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires all authorities having jurisdiction over a population exceeding five thousand residents to adopt a residential automated solar permitting platform by June thirtieth, two thousand twenty-six."
    }
