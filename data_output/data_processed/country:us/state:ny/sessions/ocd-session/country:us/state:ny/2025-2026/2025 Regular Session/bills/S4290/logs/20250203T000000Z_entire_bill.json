  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the operation of a vending machine which dispenses tobacco products unless the machine is located more than three hundred fifty feet from a building occupied exclusively as a school, church, synagogue or other place of worship."
    }
  ],
