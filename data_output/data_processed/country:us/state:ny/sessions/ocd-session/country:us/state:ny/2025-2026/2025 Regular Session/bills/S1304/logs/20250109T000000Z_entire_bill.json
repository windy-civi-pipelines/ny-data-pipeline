  "identifier": "S1304",
  "title": "Establishes the crime of criminal use of weapons; firing into a crowded space",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Makes it a class B violent felony to fire a gun into a crowded space with the intent to harm or absent the intent to harm when such an act creates a great risk of death to one or more people within the crowded space; establishes the crime of criminal use of weapons; firing into a crowded space."
    }
  ],
