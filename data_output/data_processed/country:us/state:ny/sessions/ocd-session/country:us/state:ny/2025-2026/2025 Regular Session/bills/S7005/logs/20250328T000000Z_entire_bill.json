{
  "legislative_session": "2025-2026",
  "identifier": "S7005",
  "title": "Establishing a waiver program allowing for longer stays at domestic violence shelters",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a waiver program allowing a domestic violence residential program to apply to the office of children and family services for a waiver enabling a victim of domestic violence to remain at the program's shelter for a period exceeding one hundred and eighty days."
    }
  ],
