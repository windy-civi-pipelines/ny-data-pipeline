  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for automatic issuance of identification cards to incarcerated individuals and assistance with obtaining copies of any documents needed to apply for identification cards, including, but not limited to, an incarcerated individual's social security card and birth certificate."
