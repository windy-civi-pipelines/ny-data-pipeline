  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes justice courts to exercise jurisdiction over commercial claims arising out of a transaction between a claimant and a natural person, wherein the money, property or service which is the subject of the transaction is primarily for personal, family or household purposes."
    }
