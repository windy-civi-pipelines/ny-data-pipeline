{
  "legislative_session": "2025-2026",
  "identifier": "A8849",
  "title": "Requires the department of health to facilitate the exchange of data between the state prescription drug program and electronic health records",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of health promulgate regulations allowing for any electronic health records integration vendor to obtain state approval to facilitate interoperability between the prescription monitoring program registry and certified electronic health records systems that can connect with any national data sharing hub."
    }
  ],
