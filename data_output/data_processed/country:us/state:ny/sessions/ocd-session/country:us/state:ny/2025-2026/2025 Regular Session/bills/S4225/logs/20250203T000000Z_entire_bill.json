  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the time to commence certain medical malpractice actions; provides that actions related to acts or omissions of hospitals where an incident report is required to be filed may be filed within one year of the required filing."
    }
