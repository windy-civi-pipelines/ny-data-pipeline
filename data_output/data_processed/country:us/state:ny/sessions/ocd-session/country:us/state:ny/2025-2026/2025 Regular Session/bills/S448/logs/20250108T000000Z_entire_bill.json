{
  "legislative_session": "2025-2026",
  "identifier": "S448",
  "title": "Enacts the Empowering People in Rights Enforcement (EMPIRE) Worker Protection Act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"Empowering People in Rights Enforcement (EMPIRE) Worker Protection Act\"; relates to the delegation of state enforcement authority to private actors; authorizes an affected employee, whistleblower, representative organization or an organizational deputy to initiate a public enforcement action on behalf of the commissioner for certain provisions of the labor law, or any regulation promulgated thereunder."
    }
  ],
