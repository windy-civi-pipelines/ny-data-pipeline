  "identifier": "S7725",
  "title": "Relates to decisions regarding the siting of major utility transmission facilities",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes when making a decision regarding the siting of major utility transmission facilities in the case of a gas transmission line the public service commission must determine whether the alternative method of using commercial vehicles for the purpose of transporting liquified natural gas poses a hazard to public safety."
    }
