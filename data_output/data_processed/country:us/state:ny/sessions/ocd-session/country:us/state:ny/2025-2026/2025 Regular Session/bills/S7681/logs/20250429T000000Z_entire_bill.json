  "identifier": "S7681",
  "title": "Prohibits a state or local authority from employing or designating a lobbyist to engage in lobbying",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits a state or local authority, or subsidiary thereof, from retaining, contracting, employing, or designating a lobbyist to engage in lobbying; allows for the cancellation of pre-existing contracts."
    }
  ],
