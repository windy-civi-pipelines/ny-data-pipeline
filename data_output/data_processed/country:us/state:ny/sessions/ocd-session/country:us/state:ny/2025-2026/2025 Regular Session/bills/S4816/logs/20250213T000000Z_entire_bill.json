{
  "legislative_session": "2025-2026",
  "identifier": "S4816",
  "title": "Includes Lyme disease and other tick-borne diseases as occupational diseases for purposes of workers' compensation",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Includes Lyme disease and other tick-borne diseases as occupational diseases for purposes of workers' compensation; clarifies that disability includes disability caused by Lyme disease or other tick-borne diseases; requires insurance coverage of long term medical care for Lyme disease and other tick borne diseases."
    }
  ],
