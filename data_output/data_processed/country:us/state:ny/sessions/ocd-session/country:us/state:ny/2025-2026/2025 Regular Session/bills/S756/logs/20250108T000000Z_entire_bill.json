  "identifier": "S756",
  "title": "Requires insurance contracts to cover neuropsychological examinations for dyslexia",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires insurance contracts to cover neuropsychological examinations for dyslexia when performed by a health care professional licensed, certified, or authorized pursuant to title eight of the education law and acting within their scope of practice."
    }
