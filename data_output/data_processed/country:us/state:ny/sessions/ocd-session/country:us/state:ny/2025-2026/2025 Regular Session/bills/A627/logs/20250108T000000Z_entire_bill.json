{
  "legislative_session": "2025-2026",
  "identifier": "A627",
  "title": "Relates to requiring consent of a minor's parent, legal guardian or attorney for law enforcement collection of DNA from certain minors",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the written consent of a minor's parent, legal guardian or attorney for law enforcement collection of DNA from a minor and/or pick up of a discarded sample of a minor prior to the lawful arrest of such minor."
    }
  ],
