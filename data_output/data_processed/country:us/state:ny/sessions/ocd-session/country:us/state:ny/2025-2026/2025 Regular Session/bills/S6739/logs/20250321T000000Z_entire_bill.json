{
  "legislative_session": "2025-2026",
  "identifier": "S6739",
  "title": "Relates to obtaining jurisdiction over certain defendants in matters relating to a tenancy or lease",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Standardizes the language across the relevant court acts to allow tenants statewide to sue in the county where the real property at issue is located in matters relating to a tenancy or lease; requires the Office of Court Administration to develop necessary forms, procedures and deliver a report."
    }
  ],
