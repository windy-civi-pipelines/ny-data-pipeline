  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts provisions relating to modifications, suspensions, revocations, and renewals under the air quality control program; provides for expiration of any permit which has no expiration and has been in effect for five years; provides renewal periods shall not be longer than five years."
    }
