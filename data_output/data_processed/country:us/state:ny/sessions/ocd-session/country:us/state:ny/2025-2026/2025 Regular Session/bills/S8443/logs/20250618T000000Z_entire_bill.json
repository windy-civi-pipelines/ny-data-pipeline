{
  "legislative_session": "2025-2026",
  "identifier": "S8443",
  "title": "Relates to health insurance coverage for surviving dependents following the death of a police officer by suicide",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that where an active or retired police officer dies by suicide and is enrolled in a health insurance plan, the surviving dependents of such police officer shall be entitled to such health insurance coverage for ninety days following such police officer's death."
    }
  ],
