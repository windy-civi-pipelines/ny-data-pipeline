  "identifier": "A4379",
  "title": "Relates to the establishment of an escrow account in any court which holds a special proceeding to recover real property",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires any court which holds a special proceeding to recover real property to establish an escrow account where the tenant shall submit any owed rent into such account."
    }
  ],
