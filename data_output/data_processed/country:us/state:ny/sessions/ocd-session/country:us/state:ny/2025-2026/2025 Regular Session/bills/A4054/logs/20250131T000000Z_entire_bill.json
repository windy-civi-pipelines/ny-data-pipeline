  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires retail licensees for on-premises consumption of alcohol and adult-use on-site consumption of cannabis licensees have opioid antagonists to be administered to patrons, staff or individuals on premises of such establishment."
