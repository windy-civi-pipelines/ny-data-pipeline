  "identifier": "S3640",
  "title": "Relates to warning labels on cannabis and criminalizes certain violations of restrictions on the sale of adult use cannabis",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to warning labels on cannabis products; includes advertising, deceptively advertising, branding, marketing, packaging, displaying, labelling, offering for ingestion outside of packaging, or administering cannabis products in contravention of a certain section of the cannabis law or rules and regulations in the criminal sale of cannabis in the first degree."
    }
  ],
