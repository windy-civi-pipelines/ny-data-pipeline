  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows access to juvenile delinquency records for the purposes of a firearm background check; authorizes the denial of a firearm license for an applicant who is under the age of thirty and who as a juvenile was adjudicated delinquent for an offense which, if committed by an adult, would constitute a felony or serious offense."
    }
  ],
