  "identifier": "S2089",
  "title": "Allows access to juvenile delinquency records for the purposes of a firearm background check and authorizes the denial of a firearm license for applicants under thirty who committed certain offenses as a juvenile",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
