  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"internet service outage consumer protection act\"; requires every internet service provider operating in this state to issue a prorated bill credit to consumers for any internet service outage lasting more than one hour."
    }
  ],
