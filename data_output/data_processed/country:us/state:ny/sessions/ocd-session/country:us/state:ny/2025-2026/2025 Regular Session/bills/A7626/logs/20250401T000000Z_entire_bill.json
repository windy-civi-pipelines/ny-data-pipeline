  "identifier": "A7626",
  "title": "Relates to owner liability for failure to stop at a stop sign or yield for a pedestrian",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes a municipality to adopt a local law or ordinance to establish a program imposing monetary liability on the owner of a vehicle for failure of an operator to install and operate stop sign and pedestrian crossing photo violation monitoring systems."
    }
  ],
