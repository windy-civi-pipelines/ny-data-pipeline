  "title": "Relates to stopping for a school bus on a public highway with six or more lanes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits passing a school bus on a public highway with six or more lanes when traveling the opposite direction of the stopped school bus while separated from such school bus by a median or permanent barrier."
