  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the purchase of single-use plastic products by state agencies, first limiting purchases to be used at any event, briefing, or meeting hosted or sponsored by a state agency in 2030, and a complete prohibition beginning in 2035."
    }
