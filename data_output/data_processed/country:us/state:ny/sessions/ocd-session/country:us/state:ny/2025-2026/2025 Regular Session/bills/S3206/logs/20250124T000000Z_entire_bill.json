{
  "legislative_session": "2025-2026",
  "identifier": "S3206",
  "title": "Allows a person to institute an action for a violation of the provisions of the environmental quality review even if the injury does not affect the public at large",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prevents individuals from being denied standing in private actions alleging violations of the environmental quality review provisions of the environmental conservation law solely on the basis that the injury alleged by such individual does not differ in kind or degree from the injury that would be suffered by the public at large."
    }
  ],
