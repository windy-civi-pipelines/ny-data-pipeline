  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a grant program for New York city's public K-12 schools which are eligible for support provided under Title I of the Elementary and Secondary Education Act of 1965, for the purposes of installing laundry equipment for facilities for use by students and parents or guardians of students."
