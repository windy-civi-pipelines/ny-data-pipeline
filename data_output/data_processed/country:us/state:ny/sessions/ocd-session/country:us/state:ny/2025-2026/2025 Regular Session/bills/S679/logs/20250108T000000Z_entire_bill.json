  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the affordable housing broadband assistance grant program within the division of broadband access to support no-cost and/or discounted subscriptions for households receiving federal, state, or local housing assistance or residing in housing units designated for low-income and/or vulnerable populations."
    }
