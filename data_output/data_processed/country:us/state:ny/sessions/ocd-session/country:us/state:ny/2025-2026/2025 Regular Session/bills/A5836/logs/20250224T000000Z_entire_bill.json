  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the homegrown foods act to exempt the production and sale of certain homegrown food products grown and processed at or in a private residence from certain food processing licensure requirements where the food is sold directly to consumers and total sales do not exceed $12,500."
    }
