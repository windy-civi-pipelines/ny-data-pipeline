  "identifier": "S3552",
  "title": "Establishes the parole board accountability act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the parole board accountability act which requires incarcerated individuals who are released on parole, via a vote that is not unanimous, be placed in the community where one of the two board members primarily reside; establishes the procedure of which of the two board member's community the releasee shall be released to."
    }
  ],
