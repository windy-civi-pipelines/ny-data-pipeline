  "identifier": "S5470",
  "title": "Relates to notice of profits from a crime",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that an entity which pays funds which are profits from a crime, as defined by statute, to a family member, including a former spouse, of a person charged with or convicted of a crime, give notice of such payment of funds to the office of victim services."
    }
  ],
