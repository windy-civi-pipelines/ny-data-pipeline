  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the detention support program in the office for new Americans to provide financial assistance to individuals and families of detained persons, including for bond payments to secure release from detention and travel stipends to facilitate visitation with detained individuals; establishes the detention support program fund."
    }
