  "identifier": "A5973",
  "title": "Relates to removing residency requirements for Franklin county assistant district attorneys",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Removes residency requirements for persons holding the office of assistant district attorney for the county of Franklin; provides that a person holding such office may reside in Franklin county or an adjoining county within the state."
    }
  ],
