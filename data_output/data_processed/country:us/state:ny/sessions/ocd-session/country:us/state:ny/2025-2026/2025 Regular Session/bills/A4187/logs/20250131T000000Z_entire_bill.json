  "identifier": "A4187",
  "title": "Relates to rules and regulations for advertising and marketing of cannabis",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the promulgation of rules and regulations for advertising and marketing of cannabis that include, but are not limited to, signage on the exterior walls or windows of licensed retail dispensaries; signage in languages other than English; lighting in colors other than white; other such advertising measures."
    }
