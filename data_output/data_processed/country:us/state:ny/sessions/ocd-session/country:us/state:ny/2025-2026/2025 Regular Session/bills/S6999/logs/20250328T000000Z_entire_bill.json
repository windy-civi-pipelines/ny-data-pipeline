  "identifier": "S6999",
  "title": "Enacts the \"Supervising Upcoming Professionals for Practice in Official Roles in Therapy (SUPPORT) act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"Supervising Upcoming Professionals for Practice in Official Roles in Therapy (SUPPORT) act\"; provides that for licensure as a clinical social worker, an applicant may satisfy the experience requirements under supervision of a mental health practitioner who has been granted the privilege to diagnose and develop assessment-based treatment plans under article one hundred sixty-three of the education law."
    }
  ],
