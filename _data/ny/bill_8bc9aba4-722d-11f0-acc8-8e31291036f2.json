{"legislative_session": "2025-2026", "identifier": "A1275", "title": "Relates to the crimes of commercial bribery and larceny", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "", "abstract": "Removes the $250 economic harm requirement from the felony commercial bribery statutes; expands the crime of larceny to include theft of personal identifying information, computer data, computer programs, and services, to adapt to modern technological realities; provides state jurisdiction and county venue over cases involving larceny of personal identifying information, computer data, and computer programs, where the victim is located in the state or the county."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "REFERRED TO CODES", "date": "2025-01-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [{"name": "Amy Paulin", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Amy Paulin\"}", "organization_id": null}], "related_bills": [{"identifier": "S 1693", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "S 1693", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "A 8041", "legislative_session": "2023-2024", "relation_type": "prior-session"}, {"identifier": "A 5007", "legislative_session": "2021-2022", "relation_type": "prior-session"}, {"identifier": "A 7913", "legislative_session": "2019-2020", "relation_type": "prior-session"}], "versions": [{"note": "A1275", "links": [{"url": "http://assembly.state.ny.us/leg/?sh=printbill&bn=A1275&term=2025&Text=Y", "media_type": "text/html"}, {"url": "http://legislation.nysenate.gov/pdf/bills/2025/A1275", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [], "citations": [{"publication": "New York Laws