{"legislative_session": "2025-2026", "identifier": "S6137", "title": "Appropriates monies for funding day care services to children of persons 24 and under to enable such persons to continue education; appropriation", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "", "abstract": "Provides funds for day care services for the children of persons 24 and under to enable such persons to continue secondary and post-secondary education; provides criteria to be governed by standards established for economically and educationally disadvantaged students under special opportunity programs for state and city universities; appropriates $5,600,000 to the office of children and family services therefor."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "REFERRED TO FINANCE", "date": "2025-03-05", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [{"name": "Kevin S. Parker", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Kevin S. Parker\"}", "organization_id": null}], "related_bills": [{"identifier": "A 883", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "A 883", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "S 7165", "legislative_session": "2023-2024", "relation_type": "prior-session"}, {"identifier": "S 5907", "legislative_session": "2021-2022", "relation_type": "prior-session"}, {"identifier": "S 8142", "legislative_session": "2019-2020", "relation_type": "prior-session"}, {"identifier": "A 4939", "legislative_session": "2017-2018", "relation_type": "prior-session"}, {"identifier": "A 4450", "legislative_session": "2015-2016", "relation_type": "prior-session"}, {"identifier": "A 6125", "legislative_session": "2013-2014", "relation_type": "prior-session"}, {"identifier