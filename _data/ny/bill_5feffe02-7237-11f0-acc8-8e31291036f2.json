{"legislative_session": "2025-2026", "identifier": "A7776", "title": "Establishes conviction integrity units", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "", "abstract": "Establishes conviction integrity units; describes conviction integrity units; creates definitions; provides that a prosecution agency may create a conviction integrity unit to review convictions; provides that a conviction integrity unit may make recommendations for changes in convictions and sentences obtained by the prosecution agency; grants the prosecution agency discretion regarding the conviction integrity unit's recommendations; requires notice to the victim if a petition is filed by the prosecution agency; gives the superior court the discretion to provide relief."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "REFERRED TO CODES", "date": "2025-04-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [{"name": "Al Taylor", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Al Taylor\"}", "organization_id": null}], "related_bills": [{"identifier": "S 7502", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "S 7502", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "A 3898", "legislative_session": "2023-2024", "relation_type": "prior-session"}, {"identifier": "A 3765", "legislative_session": "2021-2022", "relation_type": "prior-session"}, {"identifier": "A 10622", "legislative_session": "2019-2020", "relation_type": "prior-session"}], "versions": [{"note": "A7776", "links": [{"url": "http://assembly.state.ny.us/leg/?sh=printbill&bn=A7776&term=2025&Text=Y", "media_type": "text/html"}, {"url": "http://legislation.nysenate.gov/pdf/bills/2025/A7776", "media_type": "application/pdf"}], "dat