{"legislative_session": "2025-2026", "identifier": "S4978", "title": "Relates to media literacy education", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "", "abstract": "Enacts the \"media literacy act\"; requires teachers and library media specialists to complete professional development related to media literacy education; requires a school library media specialist in each elementary, intermediate, middle, junior high and senior high school; directs the commissioner of education to appoint a media literacy advisory committee to study the teaching of media literacy; creates a media literacy advisory committee to annually review policy and procedures on media literacy."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "REFERRED TO EDUCATION", "date": "2025-02-14", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [{"name": "Leroy Comrie", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Leroy Comrie\"}", "organization_id": null}], "related_bills": [{"identifier": "A 5821", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "A 5821", "legislative_session": "2025-2026", "relation_type": "companion"}, {"identifier": "S 8217", "legislative_session": "2023-2024", "relation_type": "prior-session"}], "versions": [{"note": "S4978", "links": [{"url": "http://assembly.state.ny.us/leg/?sh=printbill&bn=S4978&term=2025&Text=Y", "media_type": "text/html"}, {"url": "http://legislation.nysenate.gov/pdf/bills/2025/S4978", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [], "citations": [{"publication": "New York Laws", "citation": "EDN \u00a7 286", "citation_type": "proposed", "effective": null, "expires": null, "url": "https://www.nysenate.gov/legislation/laws/EDN/"}, {"public