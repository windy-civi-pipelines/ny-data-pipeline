{"legislative_session": "2025-2026", "identifier": "A1284", "title": "Enacts the \"Wandering Officers Act\"", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "", "abstract": "Enacts the \"Wandering Officers Act\" prohibiting provisional or permanent appointment of a person as a police officer if such person has previously been fired as a police officer from any jurisdiction within or without the state, if such person left a position as a police officer either while under an investigation or while being the subject of a disciplinary action which could result in termination from any jurisdiction within or without the state, or if such person resigned while criminal charges were pending stemming from actions committed while on duty as a police officer in any jurisdiction within or without the state."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "REFERRED TO GOVERNMENTAL OPERATIONS", "date": "2025-01-09", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [{"name": "Philip Ramos", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Philip Ramos\"}", "organization_id": null}, {"name": "William Colton", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"William Colton\"}", "organization_id": null}, {"name": "Jeffrey Dinowitz", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Jeffrey Dinowitz\"}", "organization_id": null}, {"name": "Phara Souffrant Forrest", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\": \"Phara Souffrant Forrest\"}", "organization_id": null}, {"name": "Deborah Glick", "classification": "cosponsor", "entity_type": "person", "primary": false, "person_id": "~{\"name\"